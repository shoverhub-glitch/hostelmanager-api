=io; from datetime import datetime, timezone; from app.database.mongodb import db; from app.utils.helpers import hash_password; \
async def main(): \
    users = db['users']; \
    now = datetime.now(timezone.utc); \
    await users.update_one( \
        {'email': 'test@shoverhub.com'}, \
        {'$set': { \
            'name': 'Test User', \
            'phone': '9123123123', \
            'password': hash_password('Test@123'), \
            'role': 'propertyowner', \
            'isEmailVerified': True, \
            'updatedAt': now \
        }, '$setOnInsert': { \
            'createdAt': now, \
            'lastLogin': None, \
            'propertyIds': [] \
        }}, \
        upsert=True \
    ); \
    print('Test user ready: test@shoverhub.com'); \
asyncio.run(main())"

