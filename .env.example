# Required
MONGO_URL=mongodb://localhost:27017/hostel_manager
JWT_SECRET=your-secret-key-min-32-chars
FROM_EMAIL=noreply@yourdomain.com
ZEPTO_MAIL_API_KEY=your-api-key

# Optional
ENV=production
ALLOWED_ORIGINS=*

# Quota Limits
MAX_PROPERTIES_PER_OWNER=3
MAX_TENANTS_PER_PROPERTY=100
MAX_ROOMS_PER_PROPERTY=40
MAX_STAFF_PER_PROPERTY=7