# ===========================================
# REQUIRED - Must configure before running
# ===========================================

# MongoDB Connection
MONGO_URL=mongodb://localhost:27017/hostel_manager

# JWT Secret - generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-this-before-production

# Email (Zepto Mail)
FROM_EMAIL=noreply@yourdomain.com
ZEPTO_MAIL_API_KEY=your-api-key

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret

# ===========================================
# IMPORTANT - ENV determines behavior
# ===========================================

# ENV defaults to "production" if not set
# ENV=development  # Uncomment to enable DEMO_OTP for testing without email

# DEMO_OTP (only works when ENV=development)
# DEMO_OTP=123456

# ===========================================
# OPTIONAL - Defaults work out of box
# ===========================================

# APP_URL=https://your-domain.com  # For payment callbacks
# ALLOWED_ORIGINS=http://localhost:3000  # Comma-separated for CORS
# ADMIN_ACCESS_EMAILS=admin@example.com  # Optional admin access
